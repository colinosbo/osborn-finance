# --- core ---
PORT=4000
NODE_ENV=development         # production refuses to boot with AUTH_MODE=dev (H1)
AUTH_MODE=dev                # dev | entra. Default is 'entra' in production, 'dev' otherwise.
DATABASE_URL=                # empty = in-memory store (dev/demo)
APP_BASE_URL=http://localhost:5173
AUDIT_IP_SALT=               # salt for the audit-log client-IP hash (L3)
# --- Entra External ID (prod auth) ---
ENTRA_JWKS_URL=
ENTRA_AUDIENCE=
ENTRA_ISSUER=                # exact tenant issuer URL, e.g. https://<tenant>.ciamlogin.com/<tid>/v2.0 — required in prod (H2)
# --- Plaid (empty = mock mode) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=
# --- Stripe (empty = mock mode) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PERSONAL=
STRIPE_PRICE_FAMILY=
STRIPE_PRICE_ENTERPRISE=
# --- crypto ---
TOKEN_ENC_KEY=               # 32-byte base64; prod: from Key Vault
TOKEN_ENC_KEY_ID=1           # current key id (1-255), prefixed onto new ciphertext (M5)
TOKEN_ENC_KEY_PREV=          # rotation window: "2:<base64>,3:<base64>" — old keys kept for decrypt only
